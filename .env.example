# ─────────────────────────────────────────────────────────────────────
# PMAOS -- Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then encrypt with age (recommended):
#   bash scripts/encrypt-env.sh
# ─────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────

# Anthropic API key (Claude)
ANTHROPIC_API_KEY=

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (send /start to @userinfobot to find it)
TELEGRAM_CHAT_ID=

# ── Bot Identity ─────────────────────────────────────────────────────

# Your bot's display name (used in logs, dashboard, and personality)
BOT_NAME=pmaos

# ── Paths ────────────────────────────────────────────────────────────

# Absolute path to this project directory
PROJECT_ROOT=

# Absolute path to your Obsidian vault (optional but recommended)
VAULT_ROOT=

# ── Optional Providers ───────────────────────────────────────────────

# Venice AI -- zero-data-retention provider for sensitive content
VENICE_API_KEY=

# OpenRouter -- access to 100+ models via single API
OPENROUTER_API_KEY=

# Google Gemini -- video understanding and multimodal
GOOGLE_API_KEY=

# Google OAuth 2.0 -- Gmail + Calendar integration (run: node dist/google-auth-setup.js)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Groq -- fast Whisper speech-to-text
GROQ_API_KEY=

# ElevenLabs -- high-quality text-to-speech
ELEVENLABS_API_KEY=

# ── Optional Messaging Channels ──────────────────────────────────────

# Discord
DISCORD_TOKEN=

# Slack
SLACK_BOT_TOKEN=

# Matrix
MATRIX_ACCESS_TOKEN=
MATRIX_HOMESERVER_URL=

# Signal (requires signal-cli REST API running)
SIGNAL_API_URL=
SIGNAL_PHONE_NUMBER=

# ── Security ─────────────────────────────────────────────────────────

# Paladin policy engine port (default: 3150)
PALADIN_PORT=3150

# Token for approval gate authentication (generate a random string)
PALADIN_APPROVAL_TOKEN=

# ── Dashboard ────────────────────────────────────────────────────────

# Dashboard auth token (generate a random string)
DASHBOARD_TOKEN=

# Dashboard port (default: 3210)
DASHBOARD_PORT=3210

# ── Database ─────────────────────────────────────────────────────────

# SQLite encryption passphrase (optional, leave blank for unencrypted)
DB_ENCRYPTION_KEY=

# ── Backups ──────────────────────────────────────────────────────────

# Backup directory (default: store/backups/)
DB_BACKUP_DIR=

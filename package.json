{
  "name": "pmaos",
  "version": "1.0.0",
  "description": "Your personal Claude Code assistant, delivered to your phone via Telegram",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "setup": "tsx scripts/setup.ts",
    "status": "tsx scripts/status.ts",
    "audit": "node dist/weekly-audit.js",
    "audit:health": "node dist/audit-service-health.js",
    "audit:vault": "node dist/audit-vault-integrity.js",
    "audit:security": "node dist/audit-security.js",
    "audit:review": "node dist/audit-red-flag-review.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.34",
    "@google/genai": "^1.45.0",
    "@hono/node-server": "^1.19.9",
    "@pixiv/three-vrm": "^3.5.1",
    "@slack/web-api": "^7.14.1",
    "better-sqlite3-multiple-ciphers": "^12.6.2",
    "ccxt": "^4.5.44",
    "cron-parser": "^5.5.0",
    "discord.js": "^14.25.1",
    "fast-xml-parser": "^5.4.2",
    "google-auth-library": "^9.15.0",
    "googleapis": "^144.0.0",
    "grammy": "^1.34.0",
    "hono": "^4.12.3",
    "js-yaml": "^4.1.1",
    "matrix-bot-sdk": "^0.8.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "qrcode-terminal": "^0.12.0",
    "sqlite-vec": "^0.1.7-alpha.2",
    "three": "^0.183.2",
    "whatsapp-web.js": "^1.34.6",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.0.0",
    "playwright": "^1.58.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "vitest": {
    "environment": "node",
    "include": [
      "src/**/*.test.ts"
    ]
  }
}

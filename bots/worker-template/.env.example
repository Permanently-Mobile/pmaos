# Worker Bot Environment Configuration
# Copy this file to .env and fill in your values

# Required: Unique name for this worker (used in bridge routing)
WORKER_NAME=my-worker

# Required: Telegram bot token for this worker's dedicated bot
TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_ID=

# Optional: Override project paths
# PROJECT_ROOT=/path/to/pmaos
# VAULT_ROOT=/path/to/vault

# Optional: Worker specialties (comma-separated)
# Used by the bridge for task routing
# WORKER_SPECIALTIES=coding,debugging,testing

# Optional: Task timeout in minutes (default: 30)
# WORKER_TASK_TIMEOUT_MIN=30

# Optional: Poll interval in milliseconds (default: 30000)
# WORKER_POLL_MS=30000
